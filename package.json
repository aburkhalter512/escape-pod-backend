{
  "name": "escape-pod-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Owns durable state (organizers, guild subscriptions, pod rounds) and the Protect the Pod integration. Called by discord-bot's internal API.",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "scripts/dev.sh",
    "dev:server": "tsx watch --env-file=.env src/server.ts",
    "db:up": "scripts/db.sh up",
    "db:down": "scripts/db.sh down",
    "db:destroy": "scripts/db.sh destroy",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "fastify": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=20"
  }
}
